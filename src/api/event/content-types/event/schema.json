    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "date": {
      "type": "datetime",
      "required": true
    },
    "time": {
      "type": "string"
    },
    "location": {
      "type": "string",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "registrationLink": {
      "type": "string"
    },
    "cpdPoints": {
      "type": "integer"
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "isPaid": {
      "type": "boolean"
    },
    "memberPrice": {
      "type": "integer"
    },
    "nonMemberPrice": {
      "type": "integer"
    }
  }
