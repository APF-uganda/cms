{
  "kind": "collectionType",
  "collectionName": "events",
  "info": {
    "singularName": "event",
    "pluralName": "events",
    "displayName": "Events"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "description": {
      "type": "text",
      "required": true
    },
    "content": {
      "type": "blocks"
    },
    "date": {
      "type": "datetime",
      "required": true
    },
    "time": {
      "type": "string"
    },
    "location": {
      "type": "string",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "registrationLink": {
      "type": "string"
    },
    "cpdPoints": {
      "type": "integer"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "\"conference\"",
        "\"workshop\"",
        "\"seminar\"",
        "\"Forum\"",
        "\"Networking\""
      ]
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "state": {
      "type": "enumeration",
      "enum": [
        "\"upcoming\"",
        "\"ongoing\"",
        "\"completed\"",
        "\"cancelled\""
      ]
    },
    "PublishAt": {
      "type": "datetime"
    }
  }
}
