{
  "kind": "collectionType",
  "collectionName": "faqs",
  "info": {
    "singularName": "faq",
    "pluralName": "faqs",
    "displayName": "FAQ"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "question": {
      "type": "text",
      "required": true
    },
    "answer": {
      "type": "blocks",
      "required": true
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "\"Membership\"",
        "\"Events\"",
        "\"General\"",
        "\"Technical\""
      ]
    },
    "order": {
      "type": "integer"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "publishAt": {
      "type": "datetime"
    }
  }
}
