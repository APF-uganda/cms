{
  "kind": "singleType",
  "collectionName": "contact_infos",
  "info": {
    "singularName": "contact-info",
    "pluralName": "contact-infos",
    "displayName": "Contact Info",
    "description": "Contact information and details"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "phone": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "address": {
      "type": "text",
      "required": true
    },
    "mapEmbedUrl": {
      "type": "string"
    },
    "officeHours": {
      "type": "text"
    },
    "socialMedia": {
      "type": "component",
      "repeatable": true,
      "component": "shared.social-link"
    }
  }
}
