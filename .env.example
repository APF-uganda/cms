# Server Configuration
HOST=0.0.0.0
PORT=1337

# Database Configuration (PostgreSQL)
DATABASE_CLIENT=postgres
DATABASE_HOST=your-database-host.neon.tech
DATABASE_PORT=5432
DATABASE_NAME=strapi_cms
DATABASE_USERNAME=your-database-username
DATABASE_PASSWORD=your-database-password
DATABASE_SSL=true

# Secrets (Generate with: openssl rand -base64 32)
ADMIN_JWT_SECRET=generate-a-random-secret-here
API_TOKEN_SALT=generate-a-random-secret-here
JWT_SECRET=generate-a-random-secret-here
TRANSFER_TOKEN_SALT=generate-a-random-secret-here

# App Keys (Generate 4 keys separated by commas)
APP_KEYS=key1,key2,key3,key4

# Node Environment
NODE_ENV=development

# Instructions:
# 1. Copy this file to .env
# 2. Replace all placeholder values with actual values
# 3. Generate secrets using: openssl rand -base64 32
# 4. Never commit .env file to git
